[Desktop Entry]
Type=Application
Version=1.0
Name=Spectacle Toolbelt
GenericName=Screenshot Power Tools
Comment=Local companion workflows for KDE Spectacle
Exec=spectacle-toolbelt scroll --manual
Icon=spectacle
Terminal=true
Categories=Graphics;KDE;Qt;
Keywords=Spectacle;Screenshot;Scrolling Capture;OCR;Redaction;ImageMagick;
StartupNotify=false
X-Spectacle-Toolbelt-Owned=true
Actions=ScrollCapture;Doctor;

[Desktop Action ScrollCapture]
Name=Start Manual Scrolling Capture
Exec=spectacle-toolbelt scroll --manual
Icon=spectacle

[Desktop Action Doctor]
Name=Run Toolbelt Doctor
Exec=spectacle-toolbelt doctor
Icon=dialog-information
