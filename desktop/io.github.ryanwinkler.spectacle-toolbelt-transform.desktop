[Desktop Entry]
Type=Application
Version=1.0
Name=Transform with Spectacle Toolbelt
GenericName=Screenshot Transform Presets
Comment=Run a safe Spectacle Toolbelt transform preset
Exec=spectacle-toolbelt transform --preset docs-clean %f
Icon=transform-crop-and-resize
Terminal=true
Categories=Graphics;KDE;Qt;
Keywords=Spectacle;Screenshot;ImageMagick;Transform;
MimeType=image/png;image/jpeg;image/webp;
StartupNotify=false
NoDisplay=true
X-Spectacle-Toolbelt-Owned=true
