[Desktop Entry]
Type=Application
Version=1.0
Name=Spectacle Toolbelt Scrolling Capture
GenericName=Scrolling Screenshot Helper
Comment=Start the Spectacle Toolbelt scrolling capture workflow
Exec=spectacle-toolbelt scroll --manual
Icon=spectacle
Terminal=true
Categories=Graphics;KDE;Qt;
Keywords=Spectacle;Screenshot;Scrolling Capture;
StartupNotify=false
X-Spectacle-Toolbelt-Owned=true
