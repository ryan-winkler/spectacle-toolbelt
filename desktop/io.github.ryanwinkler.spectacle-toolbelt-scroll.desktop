[Desktop Entry]
Type=Application
Version=1.0
Name=Spectacle Toolbelt Scrolling Capture
GenericName=Scrolling Screenshot Capture
Comment=Capture scrolling content and open the result in Spectacle
Exec=spectacle-toolbelt scroll
Icon=spectacle
Terminal=false
Categories=Graphics;KDE;Qt;
Keywords=Spectacle;Screenshot;Scrolling Capture;Snagit;ShareX;Toolbelt;
StartupNotify=false
X-KDE-DBUS-Restricted-Interfaces=org.kde.KWin.ScreenShot2
X-KDE-Wayland-Interfaces=org_kde_plasma_window_management,zkde_screencast_unstable_v1
X-Spectacle-Toolbelt-Owned=true
